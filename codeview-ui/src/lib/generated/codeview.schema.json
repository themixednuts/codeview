{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Workspace",
  "description": "Top-level workspace: per-crate graphs with cross-crate edges.",
  "type": "object",
  "properties": {
    "crates": {
      "description": "Workspace member crates (fully analyzed)",
      "type": "array",
      "items": {
        "$ref": "#/$defs/CrateGraph"
      }
    },
    "cross_crate_edges": {
      "description": "Edges that cross crate boundaries (from_crate != to_crate)",
      "type": "array",
      "items": {
        "$ref": "#/$defs/Edge"
      }
    },
    "external_crates": {
      "description": "External crate stubs (referenced but not analyzed)",
      "type": "array",
      "items": {
        "$ref": "#/$defs/ExternalCrate"
      }
    },
    "ref": {
      "description": "Git ref (branch, tag, or commit SHA) for source fetching on Cloudflare",
      "type": [
        "string",
        "null"
      ]
    },
    "repo": {
      "description": "GitHub repository (e.g. \"owner/repo\") for source fetching on Cloudflare",
      "type": [
        "string",
        "null"
      ]
    },
    "version": {
      "type": "integer",
      "format": "uint32",
      "default": 1,
      "minimum": 0
    }
  },
  "required": [
    "crates",
    "external_crates",
    "cross_crate_edges"
  ],
  "$defs": {
    "ArgumentInfo": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/TypeRef"
        }
      },
      "required": [
        "name",
        "type"
      ]
    },
    "AssocItemConstraint": {
      "description": "`IntoIterator<Item = u32, IntoIter: Clone>` — the constraints inside `<…>`.",
      "type": "object",
      "properties": {
        "args": {
          "anyOf": [
            {
              "$ref": "#/$defs/GenericArgs"
            },
            {
              "type": "null"
            }
          ]
        },
        "binding": {
          "$ref": "#/$defs/AssocItemConstraintKind"
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "binding"
      ]
    },
    "AssocItemConstraintKind": {
      "oneOf": [
        {
          "description": "`Item = u32` (type) or `BAR = 42` (const).",
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "Equality"
            },
            "value": {
              "$ref": "#/$defs/Term"
            }
          },
          "required": [
            "kind",
            "value"
          ]
        },
        {
          "description": "`Item: Clone` — bounds on the associated item.",
          "type": "object",
          "properties": {
            "bounds": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/GenericBound"
              }
            },
            "kind": {
              "type": "string",
              "const": "Constraint"
            }
          },
          "required": [
            "kind",
            "bounds"
          ]
        }
      ]
    },
    "Confidence": {
      "type": "string",
      "enum": [
        "Static",
        "Runtime",
        "Inferred"
      ]
    },
    "CrateGraph": {
      "description": "A single crate's graph data.",
      "type": "object",
      "properties": {
        "aliases": {
          "description": "Public re-export path → canonical node ID (see `Graph::aliases`).",
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "edges": {
          "description": "Internal edges (both from+to within this crate)",
          "type": "array",
          "items": {
            "$ref": "#/$defs/Edge"
          }
        },
        "id": {
          "description": "Crate identifier (e.g. \"drizzle_core\")",
          "type": "string"
        },
        "name": {
          "description": "Display name",
          "type": "string"
        },
        "nodes": {
          "description": "All nodes belonging to this crate",
          "type": "array",
          "items": {
            "$ref": "#/$defs/Node"
          }
        },
        "version": {
          "description": "Crate version string",
          "type": "string"
        }
      },
      "required": [
        "id",
        "name",
        "version",
        "nodes",
        "edges"
      ]
    },
    "Deprecation": {
      "type": "object",
      "properties": {
        "note": {
          "type": [
            "string",
            "null"
          ]
        },
        "since": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "Edge": {
      "type": "object",
      "properties": {
        "confidence": {
          "$ref": "#/$defs/Confidence"
        },
        "from": {
          "type": "string"
        },
        "is_glob": {
          "type": "boolean"
        },
        "kind": {
          "$ref": "#/$defs/EdgeKind"
        },
        "occurrences": {
          "description": "Exact source locations that justify this relationship. Empty when\nsource-backed occurrence extraction is unavailable; `Node::span`\nremains the declaration target for go-to-definition/declaration.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/Span"
          }
        },
        "to": {
          "type": "string"
        }
      },
      "required": [
        "from",
        "to",
        "kind",
        "confidence"
      ]
    },
    "EdgeKind": {
      "type": "string",
      "enum": [
        "Contains",
        "Defines",
        "Implements",
        "UsesType",
        "CallsStatic",
        "CallsRuntime",
        "Derives",
        "ReExports"
      ]
    },
    "ExternalCrate": {
      "description": "Stub for an external crate referenced by workspace crates.",
      "type": "object",
      "properties": {
        "id": {
          "description": "Crate identifier (e.g. \"std\")",
          "type": "string"
        },
        "name": {
          "description": "Display name",
          "type": "string"
        },
        "nodes": {
          "description": "Stub nodes for external items referenced by workspace crates",
          "type": "array",
          "items": {
            "$ref": "#/$defs/Node"
          }
        },
        "version": {
          "description": "Pinned version from cargo metadata (None for std/core/alloc)",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "id",
        "name",
        "nodes"
      ]
    },
    "FieldInfo": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/TypeRef"
        },
        "visibility": {
          "$ref": "#/$defs/Visibility"
        }
      },
      "required": [
        "name",
        "type",
        "visibility"
      ]
    },
    "FunctionPointerSig": {
      "description": "Function pointer signature (the `fn(...) -> ...` part of a fn-pointer type).",
      "type": "object",
      "properties": {
        "abi": {
          "type": [
            "string",
            "null"
          ]
        },
        "hrtb_params": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/GenericParam"
          }
        },
        "inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/NamedTypeRef"
          }
        },
        "is_async": {
          "type": "boolean"
        },
        "is_c_variadic": {
          "type": "boolean"
        },
        "is_const": {
          "type": "boolean"
        },
        "is_unsafe": {
          "type": "boolean"
        },
        "output": {
          "anyOf": [
            {
              "$ref": "#/$defs/TypeRef"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "inputs",
        "is_unsafe",
        "is_const",
        "is_async",
        "is_c_variadic"
      ]
    },
    "FunctionSignature": {
      "type": "object",
      "properties": {
        "abi": {
          "type": [
            "string",
            "null"
          ]
        },
        "generics": {
          "description": "Generic params + where-clause specific to this function. Trait-method\nsignatures carry their own here (separate from the impl block's\ngenerics).",
          "$ref": "#/$defs/Generics"
        },
        "inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ArgumentInfo"
          }
        },
        "is_async": {
          "type": "boolean"
        },
        "is_c_variadic": {
          "type": "boolean"
        },
        "is_const": {
          "type": "boolean"
        },
        "is_unsafe": {
          "type": "boolean"
        },
        "output": {
          "anyOf": [
            {
              "$ref": "#/$defs/TypeRef"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "inputs",
        "is_async",
        "is_unsafe",
        "is_const"
      ]
    },
    "GenericArg": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "Lifetime"
            },
            "name": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "name"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "Type"
            },
            "value": {
              "$ref": "#/$defs/TypeRef"
            }
          },
          "required": [
            "kind",
            "value"
          ]
        },
        {
          "description": "Const generic value, e.g. the `42` in `IntoIter<u32, 42>`.",
          "type": "object",
          "properties": {
            "expr": {
              "type": "string"
            },
            "is_literal": {
              "type": "boolean"
            },
            "kind": {
              "type": "string",
              "const": "Const"
            }
          },
          "required": [
            "kind",
            "expr",
            "is_literal"
          ]
        },
        {
          "description": "`_` placeholder in generic arg position: `Vec::<_>`.",
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "Infer"
            }
          },
          "required": [
            "kind"
          ]
        }
      ]
    },
    "GenericArgs": {
      "description": "`<…>` or `(…) -> _` arguments to a path segment.",
      "oneOf": [
        {
          "description": "`<'a, T, 5, Item = u32>` — args + associated-item constraints.",
          "type": "object",
          "properties": {
            "args": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/GenericArg"
              }
            },
            "constraints": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/AssocItemConstraint"
              }
            },
            "kind": {
              "type": "string",
              "const": "AngleBracketed"
            }
          },
          "required": [
            "kind",
            "args"
          ]
        },
        {
          "description": "`Fn(A, B) -> C`",
          "type": "object",
          "properties": {
            "inputs": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/TypeRef"
              }
            },
            "kind": {
              "type": "string",
              "const": "Parenthesized"
            },
            "output": {
              "anyOf": [
                {
                  "$ref": "#/$defs/TypeRef"
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "required": [
            "kind",
            "inputs"
          ]
        },
        {
          "description": "`T::method(..)` — rustdoc 1.83+ feature for return-type notation.",
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "ReturnTypeNotation"
            }
          },
          "required": [
            "kind"
          ]
        }
      ]
    },
    "GenericBound": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "hrtb_params": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/GenericParam"
              }
            },
            "kind": {
              "type": "string",
              "const": "Trait"
            },
            "modifier": {
              "$ref": "#/$defs/TraitBoundModifier"
            },
            "trait": {
              "$ref": "#/$defs/TypeRef"
            }
          },
          "required": [
            "kind",
            "trait",
            "modifier"
          ]
        },
        {
          "description": "`: 'a` outlives bound.",
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "Outlives"
            },
            "lifetime": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "lifetime"
          ]
        },
        {
          "description": "`use<'a, T>` precise-capturing bound.",
          "type": "object",
          "properties": {
            "captures": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/PreciseCapture"
              }
            },
            "kind": {
              "type": "string",
              "const": "Use"
            }
          },
          "required": [
            "kind",
            "captures"
          ]
        }
      ]
    },
    "GenericParam": {
      "description": "A single declaration in `<…>`: `T: Bound`, `'a`, `const N: usize`.",
      "type": "object",
      "properties": {
        "kind": {
          "$ref": "#/$defs/GenericParamKind"
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "kind"
      ]
    },
    "GenericParamKind": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "Lifetime"
            },
            "outlives": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "type": "object",
          "properties": {
            "bounds": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/GenericBound"
              }
            },
            "default": {
              "anyOf": [
                {
                  "$ref": "#/$defs/TypeRef"
                },
                {
                  "type": "null"
                }
              ]
            },
            "kind": {
              "type": "string",
              "const": "Type"
            },
            "synthetic": {
              "description": "Compiler-inserted synthetic parameter (e.g. lifted from\n`impl Trait` arg position) — flag so renderers can hide it.",
              "type": "boolean"
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "type": "object",
          "properties": {
            "default": {
              "type": [
                "string",
                "null"
              ]
            },
            "kind": {
              "type": "string",
              "const": "Const"
            },
            "type": {
              "$ref": "#/$defs/TypeRef"
            }
          },
          "required": [
            "kind",
            "type"
          ]
        }
      ]
    },
    "Generics": {
      "description": "Combined generic parameters + where-clause for an item. Lives on any\nitem that can be generic (fn, struct, enum, trait, impl, type alias).",
      "type": "object",
      "properties": {
        "params": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/GenericParam"
          }
        },
        "where_predicates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/WherePredicate"
          }
        }
      }
    },
    "ImplCategory": {
      "type": "string",
      "enum": [
        "Inherent",
        "Trait",
        "Blanket",
        "Negative",
        "Synthetic"
      ]
    },
    "ImplType": {
      "type": "string",
      "enum": [
        "Trait",
        "Inherent"
      ]
    },
    "NamedTypeRef": {
      "description": "`name: TypeRef` pair — used for function inputs (both fn signatures and\nfn-pointer types). For fn-pointer types the name may be empty.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/TypeRef"
        }
      },
      "required": [
        "name",
        "type"
      ]
    },
    "Node": {
      "type": "object",
      "properties": {
        "attrs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "bounds": {
          "description": "Bounds on the item (trait bounds for trait/trait-alias/impl-trait\ndeclarations, assoc-type bounds, etc.). Structured.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/GenericBound"
          }
        },
        "const_stability": {
          "anyOf": [
            {
              "$ref": "#/$defs/StabilityInfo"
            },
            {
              "type": "null"
            }
          ]
        },
        "const_value": {
          "type": [
            "string",
            "null"
          ]
        },
        "default_trait_methods": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "default_unstable": {
          "anyOf": [
            {
              "$ref": "#/$defs/ProvidedDefaultUnstable"
            },
            {
              "type": "null"
            }
          ]
        },
        "deprecation": {
          "anyOf": [
            {
              "$ref": "#/$defs/Deprecation"
            },
            {
              "type": "null"
            }
          ]
        },
        "discriminant": {
          "type": [
            "string",
            "null"
          ]
        },
        "doc_links": {
          "description": "Resolved intra-doc links: maps link text (e.g., \"Vec\") to node ID (e.g., \"std::vec::Vec\")",
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "docs": {
          "type": [
            "string",
            "null"
          ]
        },
        "extern_crate_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "extern_crate_rename": {
          "type": [
            "string",
            "null"
          ]
        },
        "fields": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/$defs/FieldInfo"
          }
        },
        "generics": {
          "description": "Generic parameters + where-clause for this item. Structured; the\nflat-string `where_clause` / `bound_links` fields it replaced are\ngone. Type IDs live inside the contained `TypeRef`s already, so\nthe worker can build cross-crate links without a side table.",
          "$ref": "#/$defs/Generics"
        },
        "has_stripped_fields": {
          "type": "boolean"
        },
        "has_stripped_variants": {
          "type": "boolean"
        },
        "id": {
          "type": "string"
        },
        "impl_category": {
          "anyOf": [
            {
              "$ref": "#/$defs/ImplCategory"
            },
            {
              "type": "null"
            }
          ]
        },
        "impl_trait": {
          "description": "For impl blocks: the ID of the trait being implemented (if trait impl)",
          "type": [
            "string",
            "null"
          ]
        },
        "impl_type": {
          "anyOf": [
            {
              "$ref": "#/$defs/ImplType"
            },
            {
              "type": "null"
            }
          ]
        },
        "import_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "import_source": {
          "type": [
            "string",
            "null"
          ]
        },
        "is_auto": {
          "type": "boolean"
        },
        "is_deprecated": {
          "type": "boolean"
        },
        "is_dyn_compatible": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "is_external": {
          "type": "boolean"
        },
        "is_glob": {
          "type": "boolean"
        },
        "is_mutable": {
          "type": "boolean"
        },
        "is_stripped": {
          "type": "boolean"
        },
        "is_unsafe": {
          "type": "boolean"
        },
        "kind": {
          "$ref": "#/$defs/NodeKind"
        },
        "line_count": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "macro_source": {
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "type": "string"
        },
        "parent_impl": {
          "description": "For methods: the ID of the parent impl block",
          "type": [
            "string",
            "null"
          ]
        },
        "proc_macro_helpers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "proc_macro_kind": {
          "type": [
            "string",
            "null"
          ]
        },
        "provided_trait_methods": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "required_trait_methods": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "signature": {
          "anyOf": [
            {
              "$ref": "#/$defs/FunctionSignature"
            },
            {
              "type": "null"
            }
          ]
        },
        "span": {
          "anyOf": [
            {
              "$ref": "#/$defs/Span"
            },
            {
              "type": "null"
            }
          ]
        },
        "stability": {
          "anyOf": [
            {
              "$ref": "#/$defs/StabilityInfo"
            },
            {
              "type": "null"
            }
          ]
        },
        "type": {
          "description": "The item's type (for Constant, Static, AssocConst, TypeAlias,\nAssocType, StructField with named field). Structured so the\nrenderer can produce links + syntax-aware highlighting.",
          "anyOf": [
            {
              "$ref": "#/$defs/TypeRef"
            },
            {
              "type": "null"
            }
          ]
        },
        "variant_kind": {
          "anyOf": [
            {
              "$ref": "#/$defs/VariantKind"
            },
            {
              "type": "null"
            }
          ]
        },
        "variants": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/$defs/VariantInfo"
          }
        },
        "visibility": {
          "$ref": "#/$defs/Visibility"
        }
      },
      "required": [
        "id",
        "name",
        "kind",
        "visibility",
        "attrs"
      ]
    },
    "NodeKind": {
      "type": "string",
      "enum": [
        "Crate",
        "Module",
        "Struct",
        "StructField",
        "Union",
        "Enum",
        "Variant",
        "Trait",
        "TraitAlias",
        "Impl",
        "Function",
