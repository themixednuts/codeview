{
	"name": "codeview-ui",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.9",
	"scripts": {
		"dev": "PUBLIC_CODEVIEW_PLATFORM=local bun --bun node_modules/vite-plus/bin/vp dev",
		"dev:clear": "rm -f ~/.codeview/cache.sqlite && vp run dev",
		"build": "PUBLIC_CODEVIEW_PLATFORM=local bun --bun node_modules/vite-plus/bin/vp build",
		"preview": "PUBLIC_CODEVIEW_PLATFORM=local bun --bun node_modules/vite-plus/bin/vp preview",
		"local": "cargo run --manifest-path ../Cargo.toml -p codeview-cli -- ui",
		"local:clear": "rm -f ~/.codeview/cache.sqlite && vp run local",
		"check": "vp run schema:check && PUBLIC_CODEVIEW_PLATFORM=local svelte-check --tsconfig ./tsconfig.json",
		"local:sync": "PUBLIC_CODEVIEW_PLATFORM=local svelte-kit sync",
		"cf:check": "vp run schema:check && PUBLIC_CODEVIEW_PLATFORM=cloudflare svelte-check --tsconfig ./tsconfig.json",
		"cf:sync": "PUBLIC_CODEVIEW_PLATFORM=cloudflare svelte-kit sync",
		"lint": "eslint src/",
		"lint:fix": "eslint src/ --fix",
		"format": "prettier --write src/",
		"format:check": "prettier --check src/",
		"test": "vp test",
		"test:run": "vp test run",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"db:generate": "drizzle-kit generate && rm -f src/lib/server/db/migrations/migrations.js",
		"db:studio": "drizzle-kit studio",
		"schema:generate": "bun scripts/generate-schema.ts",
		"schema:check": "bun scripts/generate-schema.ts --check",
		"cron:sweep": "CODEVIEW_SKIP_SIDECAR=1 cargo run --release --manifest-path ../Cargo.toml -p codeview-cli -- cron sweep",
		"cron:parse-one": "CODEVIEW_SKIP_SIDECAR=1 cargo run --release --manifest-path ../Cargo.toml -p codeview-cli -- cron parse-one",
		"cron:catalog": "CODEVIEW_SKIP_SIDECAR=1 cargo run --release --manifest-path ../Cargo.toml -p codeview-cli -- cron catalog",
		"cron:mimic": "CODEVIEW_SKIP_SIDECAR=1 cargo run --release --manifest-path ../Cargo.toml -p codeview-cli -- cron mimic",
		"cron:seed-std": "STATIC_R2_TARGET=local WRANGLER_PERSIST_TO=.wrangler/state CODEVIEW_SKIP_SIDECAR=1 cargo run --release --manifest-path ../Cargo.toml -p codeview-cli -- cron seed-std",
		"cron:seed-std:if-missing": "STATIC_R2_TARGET=local WRANGLER_PERSIST_TO=.wrangler/state CODEVIEW_SKIP_SIDECAR=1 cargo run --release --manifest-path ../Cargo.toml -p codeview-cli -- cron seed-std --if-missing",
		"cf:types": "vp run cf:types:app",
		"cf:types:app": "wrangler types src/cloudflare.d.ts --config ./wrangler.toml",
		"cf:build": "PUBLIC_CODEVIEW_PLATFORM=cloudflare vp build",
		"cf:dev": "PUBLIC_CODEVIEW_PLATFORM=cloudflare vp run cf:build && vp run cron:seed-std:if-missing && PUBLIC_CODEVIEW_PLATFORM=cloudflare wrangler dev -c ./wrangler.toml --local --persist-to .wrangler/state --live-reload",
		"cf:dev:clear": "rm -rf .wrangler && vp run cf:dev",
		"cf:deploy:app": "wrangler deploy",
		"cf:deploy": "vp run cf:build && vp run cf:deploy:app"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260504.1",
		"@eslint/js": "^10.0.1",
		"@eslym/sveltekit-adapter-bun": "^2.0.5",
		"@excalidraw/excalidraw": "^0.18.0",
		"@internationalized/date": "^3.10.0",
		"@jesterkit/exe-sveltekit": "^0.1.7",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.59.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.4",
		"@types/bun": "^1.3.13",
		"@types/d3-force": "^3.0.10",
		"@types/markdown-it": "^14.1.2",
		"@types/node": "^25.6.0",
		"@typescript-eslint/types": "^8.54.0",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"drizzle-kit": "^1.0.0-beta.9-e89174b",
		"eslint": "^10.0.0",
		"eslint-plugin-better-tailwindcss": "^4.1.1",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.3.0",
		"json-schema-to-typescript": "^15.0.4",
		"mode-watcher": "^1.1.0",
		"paneforge": "^1.0.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.7",
		"svelte-eslint-parser": "^1.6.0",
		"tailwind-merge": "^3.4.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.4",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "npm:@voidzero-dev/vite-plus-core@0.2.2",
		"vite-plus": "0.2.2",
		"vitest": "4.1.9",
		"wrangler": "^4.87.0"
	},
	"patchedDependencies": {
		"@jesterkit/exe-sveltekit@0.1.7": "patches/@jesterkit%2Fexe-sveltekit@0.1.7.patch"
	},
	"overrides": {
		"clsx": "^2.1.1",
		"fast-xml-parser": ">=5.3.4",
		"dompurify": ">=3.2.4",
		"nanoid": ">=5.0.9",
		"mermaid": ">=10.9.4",
		"cookie": ">=0.7.0",
		"vite": "npm:@voidzero-dev/vite-plus-core@0.2.2",
		"vitest": "4.1.9"
	},
	"dependencies": {
		"@logtape/logtape": "^2.0.2",
		"@lucide/svelte": "^0.561.0",
		"@shikijs/transformers": "^3.22.0",
		"@streamparser/json-whatwg": "^0.0.22",
		"@xyflow/svelte": "^1.6.1",
		"better-result": "^2.7.0",
		"d3-force": "^3.0.0",
		"drizzle-orm": "^1.0.0-beta.9-e89174b",
		"effect": "^4.0.0-beta.60",
		"markdown-it": "^14.1.0",
		"markdown-it-github-alerts": "^1.0.1",
		"runed": "^0.37.1",
		"shiki": "^3.22.0",
		"svelte-sonner": "^1.0.7",
		"valibot": "^1.2.0"
	}
}
